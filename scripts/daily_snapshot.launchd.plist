<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.yupen-model.daily-snapshot</string>

    <key>ProgramArguments</key>
    <array>
      <string>/usr/bin/python3</string>
      <string>/Users/xiedonghua/Desktop/AI/claude/yupen-model/scripts/generate_daily_yupen_snapshot.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/xiedonghua/Desktop/AI/claude/yupen-model</string>

    <key>StartCalendarInterval</key>
    <dict>
      <key>Hour</key>
      <integer>18</integer>
      <key>Minute</key>
      <integer>10</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/tmp/yupen-daily-snapshot.out</string>
    <key>StandardErrorPath</key>
    <string>/tmp/yupen-daily-snapshot.err</string>
    <key>RunAtLoad</key>
    <true/>
  </dict>
</plist>
